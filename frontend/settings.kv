
<SettingsScreen>:
    name: "settings"
    canvas.before:
        Color:
            rgba: root.bg_color
        Rectangle:
            size: self.size
            pos: self.pos

    BoxLayout:
        orientation: 'vertical'
        padding: [30, 40, 30, 30]
        spacing: 20

        Label:
            text: "Настройки"
            font_size: '24sp'
            bold: True
            color: root.txt_color
            size_hint_y: None
            height: '60dp'

        Label:
            text: "Недельная цель"
            font_size: '18sp'
            bold: True
            color: root.txt_color
            size_hint_y: None
            height: '28dp'

        Label:
            text: root.goal_text
            font_size: '20sp'
            color: root.txt_color
            bold: True
            size_hint_y: None
            height: '30dp'

        Slider:
            min: 100
            max: 500
            step: 10
            value: root.goal_value
            cursor_size: '20dp', '20dp'
            value_track: True
            value_track_color: 0.298, 0.686, 0.314, 1
            size_hint_y: None
            height: '40dp'
            on_value: root.on_goal_change(self.value)

        Label:
            text: "Уведомления"
            font_size: '18sp'
            bold: True
            color: root.txt_color
            size_hint_y: None
            height: '28dp'



        Widget:
            size_hint_y: 0.3

        BoxLayout:
            size_hint_y: None
            height: '50dp'
            spacing: 10

            Button:
                text: "Сохранить"
                background_normal: ''
                background_color: 0.298, 0.686, 0.314, 1
                bold: True
                on_release: root.save_current_settings()

            Button:
                text: "Сбросить неделю"
                background_normal: ''
                background_color: 1.0, 0.596, 0.0, 1
                bold: True
                on_release: root.reset_week_only()

            Button:
                text: "Сбросить всё"
                background_normal: ''
                background_color: 0.85, 0.3, 0.3, 1
                bold: True
                on_release: root.reset_settings()

        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: '50dp'
            spacing: 10
            pos_hint: {'center_x': 0.5}
            size_hint_x: None
            width: '210dp'

            Button:
                text: "ВКЛ" if root.notif_state else "ВЫКЛ"
                background_normal: ''
                background_color: (0.3, 0.69, 0.31, 1) if root.notif_state else (1, 0.6, 0, 1)
                bold: True
                size_hint: None, 1
                width: '100dp'
                on_release: root.toggle_notifications()

            Button:
                text: "Светлая" if root.bg_color == [0.1, 0.1, 0.12, 1] else "Темная"
                color: root.txt_color

                background_normal: ''
                background_color: [0.2, 0.2, 0.3, 1] if root.bg_color == [0.973, 0.976, 0.980, 1] else [0.3, 0.3, 0.4, 1]
                bold: True
                size_hint: None, 1
                width: '120dp'
                on_release: root.toggle_theme()

        Label:
            id: save_status
            text: ""
            font_size: '16sp'
            color: root.txt_color
            size_hint_y: None
            height: '24dp'

        BoxLayout:
            size_hint_y: None
            height: '60dp'
            spacing: 10

            Button:
                text: "Тренировка"
                background_normal: ''
                background_color: 0.2, 0.2, 0.3, 1
                on_release: root.go_to("workout")

            Button:
                text: "Статистика"
                background_normal: ''
                background_color: 0.2, 0.2, 0.3, 1
                on_release: root.go_to("stats")

            Button:
                text: "Настройки"
                background_normal: ''
                background_color: 0.2, 0.7, 1, 1
                bold: True
