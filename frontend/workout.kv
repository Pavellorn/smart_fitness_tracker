
<WorkoutScreen>:
    name: "workout"
    canvas.before:
        Color:
            rgba: root.bg_color
        Rectangle:
            size: self.size
            pos: self.pos

    BoxLayout:
        orientation: 'vertical'
        padding: [30, 40, 30, 30]
        spacing: 20

        Label:
            text: "ТРЕНИРОВКА"
            font_size: '24sp'
            bold: True
            color: root.txt_color
            size_hint_y: None
            height: '60dp'

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'
            size_hint_y: None
            height: '280dp'

            RelativeLayout:
                id: progress_circle
                size_hint: None, None
                size: '250dp', '250dp'

                canvas.before:
                    Color:
                        rgba: 1, 1, 1, 1
                    RoundedRectangle:
                        size: self.size
                        pos: self.pos
                        radius: [20, 20, 20, 20]

                canvas:
                    Color:
                        rgba: 0.85, 0.85, 0.88, 1
                    Line:
                        circle: (self.width / 2, self.height / 2, self.width / 2 - 20)
                        width: 5

                    Color:
                        # rgba: 0.298, 0.686, 0.314, 1
                        rgba: root.circle_color
                    Line:
                        circle: (self.width / 2, self.height / 2, self.width / 2 - 20, 0, root.progress_angle)
                        width: 5
                        cap: 'round'

                Label:
                    id: heart_icon
                    text: "\u2764"
                    font_name: "DejaVuSans"
                    font_size: '80sp'
                    color: root.txt_color
                    size_hint: None, None
                    size: self.parent.size
                    pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                    align: 'center'
                    valign: 'middle'

        Label:
            text: root.timer_text
            font_size: '52sp'
            bold: True
            color: root.txt_color
            size_hint_y: None
            height: '65dp'

        Label:
            text: root.percent_text
            font_size: '20sp'
            color: 0.298, 0.686, 0.314, 1
            size_hint_y: None
            height: '28dp'
            color: root.txt_color

        Label:
            text: root.status_text
            font_size: '18sp'
            color: root.txt_color
            size_hint_y: None
            height: '28dp'

        Label:
            text: root.today_total_text
            font_size: '16sp'
            color: root.txt_color
            size_hint_y: None
            height: '24dp'

        GridLayout:
            cols: 3
            spacing: 15
            size_hint_y: None
            height: '70dp'

            Button:
                text: "30 мин"
                background_normal: ''
                background_color: 0.298, 0.686, 0.314, 1
                bold: True
                on_release: root.start_workout(30)

            Button:
                text: "60 мин"
                background_normal: ''
                background_color: 1.0, 0.596, 0.0, 1
                bold: True
                on_release: root.start_workout(60)

            Button:
                text: "90 мин"
                background_normal: ''
                background_color: 0.85, 0.3, 0.3, 1
                bold: True
                on_release: root.start_workout(90)

        GridLayout:
            cols: 3
            spacing: 15
            size_hint_y: None
            height: '60dp'

            Button:
                text: "Пауза"
                background_normal: ''
                background_color: 0.45, 0.45, 0.5, 1
                on_release: root.pause_workout()

            Button:
                text: "Продолжить"
                background_normal: ''
                background_color: 0.298, 0.686, 0.314, 1
                on_release: root.resume_workout()

            Button:
                text: "Сброс"
                background_normal: ''
                background_color: 0.85, 0.3, 0.3, 1
                on_release: root.cancel_workout()

        Widget:

        BoxLayout:
            size_hint_y: None
            height: '60dp'
            spacing: 10

            Button:
                text: "Тренировка"
                background_normal: ''
                background_color: 0.2, 0.7, 1, 1

            Button:
                text: "Статистика"
                background_normal: ''
                background_color: 0.2, 0.2, 0.3, 1
                on_release: root.go_to("stats")

            Button:
                text: "Настройки"
                background_normal: ''
                background_color: 0.2, 0.2, 0.3, 1
                on_release: root.go_to("settings")
